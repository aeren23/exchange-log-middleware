# Exchange Log Middleware - Environment Variables Example
# Bu dosya şablondur. Gerçek değerleri atamak için bu dosyayı kopyalayıp adını ".env" yapın.

# RabbitMQ Credentials
RABBITMQ_USER=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password

# Azure Service Bus Emulator Credentials
SQL_EDGE_PASSWORD=your_secure_sql_password
ASB_CONNECTION_STRING=Endpoint=sb://your_servicebus_url;SharedAccessKeyName=YourPolicy;SharedAccessKey=YourKey;

# Producer Configuration
PRODUCER_LOGS_PER_SECOND=10
PRODUCER_ERROR_RATE=0.3

# Pipeline Configuration (Middleware)
PIPELINE_MINIMUM_LOG_LEVEL=ERROR
PIPELINE_DEDUP_CACHE_TTL_MINUTES=10
PIPELINE_CHANNEL_CAPACITY=1000

# Router Configuration
# Format is handled through appsettings.json, but OutputDirectory could be overridden if needed
ROUTER_OUTPUT_DIRECTORY=/app/output
