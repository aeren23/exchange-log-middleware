{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "MessageBroker": {
    "Provider": "RabbitMQ",
    "RabbitMQ": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "QueueName": "exchange-logs"
    },
    "AzureServiceBus": {
      "ConnectionString": "",
      "QueueName": "exchange-logs"
    }
  },
  "Pipeline": {
    "MinimumLogLevel": "ERROR",
    "DeduplicationCacheTtlMinutes": 10,
    "ChannelCapacity": 1000
  },
  "Output": {
    "BasePath": "/app/output"
  }
}
