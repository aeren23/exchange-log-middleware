<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Docker build içinde Windows fallback package path'lerini devre dışı bırakır.
       'C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages' gibi
       host-spesifik path'ler Linux container'ında bulunamaz. -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
